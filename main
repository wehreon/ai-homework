import os
import random

class Student:#Student数据类：用于存储学生信息，初始化学生的五种属性
    
    def __init__(self, student_id, name, gender, class_name, college):
        self.student_id = student_id
        self.name = name
        self.gender = gender
        self.class_name = class_name
        self.college = college
    
    def __str__(self):#魔术方法：定义对象的字符串表示，适用于返回格式化的学生信息，便于用户阅读
        return (f"学号：{self.student_id}\n"
                f"姓名：{self.name}\n"
                f"性别：{self.gender}\n"
                f"班级：{self.class_name}\n"
                f"学院：{self.college}")


class ExamSystem:
    
    @staticmethod#这是一个验证学号格式的静态方法，通过类名直接调用，不用创建实际的例子，用于对学号进行基础格式校验
    def validate_student_id(student_id):
        if student_id and student_id.isdigit() and len(student_id) == 8:
            return True
        return False
    
    def __init__(self, file_path):
        self.students = {}
        self.total_count = 0
        self.load_students(file_path)
    
    def load_students(self, file_path):#用于从文本文件加载学生信息
        try:
            with open(file_path, 'r', encoding='utf-8') as f:# 使用with open自动管理文件资源，encoding='utf-8'确保中文正常读取
                lines = f.readlines()
                
                for line in lines[1:]:#从第二行开始读取是为了跳过第一行标题行
                    parts = line.strip().split(',')# # strip()去除行首尾的空白字符（包括换行符），split(',')按逗号分割，返回字符串列表
                    
                    if len(parts) == 5:
                        student_id = parts[0].strip()
                        name = parts[1].strip()
                        gender = parts[2].strip()
                        class_name = parts[3].strip()
                        college = parts[4].strip()
                        
                        self.students[student_id] = Student( student_id, name, gender, class_name, college)# 创建Student对象，存入字典
            
            self.total_count = len(self.students)
            print(f"✓ 成功加载 {self.total_count} 名学生信息")
            
        except FileNotFoundError:
            print(f"✗ 错误：文件 '{file_path}' 不存在！")
            print("  请确保文件在程序根目录下")
            raise
        except Exception as e:
            print(f"✗ 加载文件时发生未知错误：{e}")
            raise
    
    def find_student(self, student_id):
        return self.students.get(student_id)
    
    def display_student_info(self, student_id):
        student = self.find_student(student_id)
        
        if student:# 找到学生，打印分隔线和信息
            print("\n" + "=" * 40)
            print("学生信息如下：")
            print(student)
            print("=" * 40)
        else:
            print(f"\n✗ 错误：学号 '{student_id}' 不存在！")
            print("  请检查学号是否正确后重新输入")
     def random_call(self, count):
    try:#使用try-except捕获非数字输入异常
        count = int(count)
        
        if count <= 0:
            print(f"\n✗ 错误：点名人数必须大于0！")
            return []
        
        if count > self.total_count:#验证数量是否合法（>0且不超过总人数）
            print(f"\n✗ 错误：点名人数不能超过总人数 {self.total_count}！")
            return []
        
        all_students = list(self.students.values())
        selected = random.sample(all_students, count)#使用random.sample实现不重复随机抽取
        
        print("\n" + "=" * 50)
        print(f"随机点名结果（共{count}人）：")
        print("=" * 50)
        for i, student in enumerate(selected, 1):
            print(f"{i:2d}. {student.name} ({student.student_id}) - {student.class_name} - {student.college}")#格式化输出点名结果
        print("=" * 50)
        
        return selected
        
    except ValueError:
        print(f"\n✗ 错误：请输入有效的数字！")
        return []


def main():
    print("=" * 50)
    print("    学生信息管理系统 - Stage1")
    print("=" * 50)
    
    file_path = "人工智能编程语言学生名单.txt"# 定义学生名单文件路径
    
    try:
        system = ExamSystem(file_path)
    except Exception as e:
        print(f"\n系统初始化失败，程序无法继续运行")
        return
    
    while True:
        print("\n" + "-" * 40)
        print("功能：学号查找")
        print("提示：输入 'q' 或 'quit' 退出程序")
        print("-" * 40)
        
        student_id = input("请输入学号（8位数字）：").strip()
        
        if student_id.lower() in ['q', 'quit', 'exit']:
            print("\n感谢使用，再见！")
            break
        
        if not ExamSystem.validate_student_id(student_id):
            print(f"\n✗ 学号格式错误：'{student_id}' 不是有效的8位数字学号")
            continue
        
        system.display_student_info(student_id)# 格式正确，调用display_student_info显示学生信息


if __name__ == "__main__":
    main()
